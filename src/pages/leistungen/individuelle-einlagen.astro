---
import Leistung from '../../layouts/Leistung.astro';
const base = import.meta.env.BASE_URL;
---

<Leistung title="Individuelle Einlagen" description="Maßgefertigte Einlagen nach umfassender Fußanalyse — für Alltag, Sport und spezielle Beschwerden." icon="🦶">
  <h2 class="font-heading text-2xl font-bold text-primary mb-4">Mehr als eine Einlage — Ihre individuelle Lösung</h2>
  <p class="text-text-light leading-relaxed mb-6">
    Eine gute Einlage beginnt nicht bei der Fertigung, sondern bei der Analyse. Bei OrthoFit in Magdeburg steht vor jeder Einlagenversorgung eine umfassende Untersuchung Ihrer Füße, Ihrer Bewegungsmuster und Ihrer Beschwerden.
  </p>

  <h3 class="font-heading text-xl font-bold text-primary mb-3">Unsere Analyse — Ihr Fundament</h3>
  <p class="text-text-light leading-relaxed mb-4">Bevor wir Ihre Einlagen konstruieren, führen wir durch:</p>
  <ul class="list-disc pl-6 text-text-light space-y-2 mb-6">
    <li>Umfassende Fußuntersuchung</li>
    <li>Bewegungsbeobachtung und Ganganalyse</li>
    <li>Schmerzanalyse und Befunderhebung</li>
    <li>Elektronische Fußdruckmessung</li>
  </ul>

  <h3 class="font-heading text-xl font-bold text-primary mb-3">Einlagen für jeden Einsatzbereich</h3>
  <div class="grid sm:grid-cols-3 gap-4 my-6">
    <div class="bg-bg-alt rounded-lg p-4">
      <p class="font-semibold text-primary mb-2">Alltag</p>
      <p class="text-sm text-text-light">Für den täglichen Gebrauch — bei Fehlstellungen, Druckstellen oder Fußschmerzen.</p>
    </div>
    <div class="bg-bg-alt rounded-lg p-4">
      <p class="font-semibold text-primary mb-2">Sport</p>
      <p class="text-sm text-text-light">Sportartspezifisch abgestimmt auf Ihre Belastung und Ihr Trainingsvolumen.</p>
    </div>
    <div class="bg-bg-alt rounded-lg p-4">
      <p class="font-semibold text-primary mb-2">Medizinisch</p>
      <p class="text-sm text-text-light">Bei Diabetes, Rheuma oder nach Operationen — mit besonderem Schutz.</p>
    </div>
  </div>

  <img src={`${base}images/grafik-einlagen-aufbau.webp`} alt="Aufbau einer individuellen orthopädischen Einlage – Schichten und Materialien" class="mx-auto my-8 max-w-md" width="600" height="600" loading="lazy" />

  <p class="text-text-light leading-relaxed">
    Auf Basis dieser individuellen Daten konstruieren wir Ihre Einlagen mit modernster Technologie — exakt angepasst an Ihre Füße, Ihre Schuhe und Ihren Alltag in Magdeburg und Umgebung.
  </p>
</Leistung>
