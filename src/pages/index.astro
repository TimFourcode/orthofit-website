---
import Base from '../layouts/Base.astro';
import { site, standorte, leistungen } from '../data/site';
const base = import.meta.env.BASE_URL;
---

<Base
  title="Start"
  description="OrthoFit Schuhtechnik Magdeburg – Orthopädische Maßschuhe, individuelle Einlagen, BIOPATHOTEC Schmerzkonzept & Bewegungsanalyse. Ihr Orthopädie-Schuhmachermeister Volker Herbst."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white overflow-hidden">
    <img src={`${base}images/foto-laden-magdeburg-web.webp`} alt="" class="absolute inset-0 w-full h-full object-cover" width="1600" height="1067" loading="eager" />
    <div class="absolute inset-0 bg-primary/80"></div>
    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-28">
      <div class="max-w-2xl">
        <p class="text-accent font-medium mb-3">Orthopädie-Schuhtechnik in Magdeburg</p>
        <h1 class="font-heading text-3xl md:text-5xl font-bold leading-tight mb-4 md:mb-6">
          Wir packen das Problem<br />an der Wurzel.
        </h1>
        <p class="text-base md:text-lg text-white/85 mb-6 md:mb-8 leading-relaxed">
          Seit über 20 Jahren vertrauen Patienten auf unsere Expertise —
          von Maßschuhen über Einlagen bis zur Bewegungsanalyse.
          <span class="hidden sm:inline"> Wir finden die Ursache Ihrer Beschwerden und behandeln sie nachhaltig.</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="bg-accent text-white font-semibold px-8 py-4 rounded-lg hover:bg-accent-light transition-colors text-center text-lg">
            Jetzt Termin vereinbaren
          </a>
          <a href={`${base}leistungen/schmerzkonzept/`} class="border border-white/40 text-white px-8 py-4 rounded-lg hover:bg-white/10 transition-colors text-center">
            BIOPATHOTEC entdecken
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- USPs -->
  <section class="bg-white py-12">
    <div class="max-w-6xl mx-auto px-4 grid md:grid-cols-3 gap-8">
      {[
        { icon: '🔬', title: 'Ursachenforschung', text: 'Wir behandeln nicht nur Symptome — wir analysieren Ihren gesamten Bewegungsapparat und finden die Ursache.' },
        { icon: '🤲', title: 'Handwerkskunst', text: 'Jeder Maßschuh wird individuell auf Ihrem persönlichen Leisten handgefertigt — mit über 20 Jahren Erfahrung.' },
        { icon: '💡', title: 'BIOPATHOTEC', text: 'Unser innovatives biomechanisches Schmerzkonzept lindert Beschwerden an Fuß, Knie, Hüfte und Wirbelsäule.' },
      ].map((usp) => (
        <div class="text-center p-6">
          <div class="text-4xl mb-4">{usp.icon}</div>
          <h3 class="font-heading text-xl font-bold text-primary mb-3">{usp.title}</h3>
          <p class="text-text-light leading-relaxed">{usp.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Leistungen -->
  <section class="py-16 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-bold text-primary mb-4">Unsere Leistungen</h2>
        <p class="text-text-light max-w-2xl mx-auto">Umfassende orthopädische Versorgung — von der Analyse bis zur fertigen Lösung, alles aus einer Hand.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {leistungen.map((l) => (
          <a href={`${base}leistungen/${l.slug}/`} class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow group">
            <div class="text-3xl mb-3">{l.icon}</div>
            <h3 class="font-semibold text-lg text-primary group-hover:text-primary-light transition-colors mb-2">{l.title}</h3>
            <p class="text-sm text-text-light">{l.kurz}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Über uns -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-accent font-medium mb-2">Über uns</p>
          <h2 class="font-heading text-3xl font-bold text-primary mb-6">Orthopädie-Schuhmachermeister Volker Herbst</h2>
          <p class="text-text-light leading-relaxed mb-4">
            Als Orthopädie-Schuhmachermeister führt Volker Herbst die OrthoFit Schuhtechnik GmbH mit einem sechsköpfigen Team aus Fachkräften und Sportwissenschaftlern.
          </p>
          <p class="text-text-light leading-relaxed mb-4">
            Durch kontinuierliche Weiterbildung und enge Zusammenarbeit mit Ärzten und Wissenschaftlern bieten wir Ihnen stets modernste Versorgungskonzepte — vom Maßschuh bis zur computergestützten Bewegungsanalyse.
          </p>
          <blockquote class="border-l-4 border-accent pl-4 my-6 italic text-primary">
            „Wir betreiben Ursachenforschung und packen das Problem an der Wurzel."
            <footer class="text-sm text-text-light mt-1 not-italic">— Volker Herbst, Geschäftsführer</footer>
          </blockquote>
        </div>
        <img src={`${base}images/foto-laden-magdeburg-web.webp`} alt="OrthoFit Schuhtechnik Ladengeschäft am Universitätsplatz in Magdeburg" class="rounded-2xl w-full object-cover shadow-lg" width="1600" height="1067" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Standorte -->
  <section class="py-16 bg-bg-alt">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-bold text-primary mb-4">Unsere Standorte</h2>
        <p class="text-text-light">Besuchen Sie uns in Magdeburg oder Schönhausen — Termine nach Vereinbarung.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {standorte.map((s) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-heading text-xl font-bold text-primary mb-1">{s.name}</h3>
            {s.hauptstandort && <span class="text-xs bg-accent/20 text-accent px-2 py-0.5 rounded font-medium">Hauptstandort</span>}
            <div class="mt-4 space-y-2 text-sm text-text-light">
              <p>{s.street}, {s.zip} {s.city}</p>
              <p>
                <a href={`tel:${s.phone.replace(/\s/g, '')}`} class="text-primary hover:text-primary-light font-medium">{s.phone}</a>
              </p>
            </div>
            <div class="mt-4">
              <h4 class="text-sm font-semibold mb-2">Öffnungszeiten</h4>
              <dl class="text-sm text-text-light space-y-1">
                {s.oeffnungszeiten.map((o) => (
                  <div class="flex justify-between">
                    <dt class="font-medium text-text">{o.tag}</dt>
                    <dd>{o.zeit}</dd>
                  </div>
                ))}
              </dl>
            </div>
            <div class="mt-4">
              {s.hauptstandort ? (
                <img src={`${base}images/karte-magdeburg.webp`} alt="Anfahrtskarte OrthoFit Magdeburg – Universitätsplatz 11" class="w-full rounded-lg" width="592" height="384" loading="lazy" />
              ) : (
                <img src={`${base}images/karte-schoenhausen.webp`} alt="Anfahrtskarte OrthoFit Schönhausen – Bismarckstraße 8" class="w-full rounded-lg" width="901" height="560" loading="lazy" />
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-heading text-3xl font-bold mb-4">Beschwerden im Bewegungsapparat?</h2>
      <p class="text-white/80 mb-8">Rufen Sie uns an — wir beraten Sie persönlich und finden gemeinsam die beste Lösung für Ihre Füße.</p>
      <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="inline-block bg-accent text-white font-semibold px-10 py-4 rounded-lg hover:bg-accent-light transition-colors text-lg">
        {site.phone}
      </a>
    </div>
  </section>
</Base>
