---
import { site, navigation } from '../data/site';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <!-- Topbar -->
  <div class="bg-primary text-white text-sm">
    <div class="max-w-6xl mx-auto px-4 py-2 flex justify-between items-center">
      <div class="flex items-center gap-4">
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="hover:text-accent-light flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {site.phone}
        </a>
        <a href={`mailto:${site.email}`} class="hover:text-accent-light hidden sm:flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {site.email}
        </a>
      </div>
      <div class="flex items-center gap-3">
        <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="hover:text-accent-light">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
        </a>
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="hover:text-accent-light">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Main Nav -->
  <nav class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
    <a href={base} class="flex items-center gap-3">
      <img src={`${base}images/logo-orthofit.webp`} alt="OrthoFit Schuhtechnik GmbH" class="h-10 w-auto" />
      <span class="text-sm text-text-light hidden sm:block">Schuhtechnik Magdeburg</span>
    </a>

    <!-- Desktop Menu -->
    <ul class="hidden md:flex items-center gap-6 text-sm font-medium">
      {navigation.map((item) => (
        <li class="relative group">
          <a
            href={`${base}${item.href.slice(1)}`}
            class:list={[
              'py-2 transition-colors',
              currentPath === item.href || currentPath.startsWith(item.href + '/') && item.href !== '/'
                ? 'text-primary font-semibold'
                : 'text-text hover:text-primary',
            ]}
          >
            {item.label}
            {'children' in item && (
              <svg class="w-3 h-3 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            )}
          </a>
          {'children' in item && (
            <ul class="absolute top-full left-0 bg-white shadow-lg rounded-lg py-2 min-w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
              {item.children.map((child) => (
                <li>
                  <a href={`${base}${child.href.slice(1)}`} class="block px-4 py-2 text-sm text-text hover:bg-bg-alt hover:text-primary transition-colors">
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
      <li>
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="bg-primary text-white px-5 py-2.5 rounded-lg hover:bg-primary-light transition-colors">
          Termin vereinbaren
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menü öffnen">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
    <ul class="px-4 py-4 space-y-3">
      {navigation.map((item) => (
        <li>
          <a href={`${base}${item.href.slice(1)}`} class="block py-2 text-text hover:text-primary font-medium">{item.label}</a>
          {'children' in item && (
            <ul class="pl-4 mt-1 space-y-1">
              {item.children.map((child) => (
                <li><a href={child.href} class="block py-1.5 text-sm text-text-light hover:text-primary">{child.label}</a></li>
              ))}
            </ul>
          )}
        </li>
      ))}
      <li class="pt-2">
        <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="block text-center bg-primary text-white px-5 py-2.5 rounded-lg hover:bg-primary-light transition-colors">
          Termin vereinbaren
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
